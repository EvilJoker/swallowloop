# SwallowLoop 配置

# ============ 必需配置 ============

# 目标仓库 (owner/repo 格式，支持多仓库用逗号分隔)
REPOS=yourname/your-repo

# ============ LLM 配置 ============
# 可选：配置自定义 LLM（如 Minimax）

# LLM 提供商: openai, minimax, custom
# LLM_PROVIDER=minimax

# API Key
# LLM_API_KEY=your_api_key

# API Base URL
# LLM_BASE_URL=https://api.minimaxi.com/v1

# 模型名称
# LLM_MODEL_NAME=MiniMax-M2.7-highspeed

# ============ 端口配置 ============

# 后端 API 端口
BACKEND_PORT=9500

# 前端 Dashboard 端口
FRONTEND_PORT=9501

# ============ Agent 配置 ============

# Agent 类型: mock (模拟 Agent), deerflow (DeerFlow 2.0)
# deerflow 需要独立部署 DeerFlow Docker 容器
AGENT_TYPE=mock

# ============ Worker Agent 配置 ============

# Worker 超时 (秒)
WORKER_TIMEOUT=600

# 轮询间隔 (秒)
POLL_INTERVAL=60

# 监听的 Issue 标签
ISSUE_LABEL=swallow

# 基础分支
BASE_BRANCH=main
