# SwallowLoop 配置

# ============ 必需配置 ============

# GitHub Token (需要 repo 权限)
GITHUB_TOKEN=your_github_token_here

# 目标仓库 (owner/repo 格式)
GITHUB_REPO=yourname/your-repo

# ============ Minimax API 配置 ============

# 使用 OpenAI 兼容模式
OPENAI_API_KEY=your_minimax_api_key

# Minimax API 地址
OPENAI_API_BASE_URL=https://api.minimaxi.com/v1

# ============ Worker Agent 配置 ============

# Agent 类型 (iflow 或 aider，默认 iflow)
AGENT_TYPE=iflow

# LLM 模型 (使用 minimax 模型)
LLM_MODEL=openai/MiniMax-M2.5-highspeed

# Worker 超时 (秒)
WORKER_TIMEOUT=600

# 轮询间隔 (秒)
POLL_INTERVAL=60

# 监听的 Issue 标签
ISSUE_LABEL=swallow

# 基础分支
BASE_BRANCH=main
