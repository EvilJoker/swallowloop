# SwallowLoop 配置

# ============ 必需配置 ============

# GitHub Token (需要 repo 权限)
GITHUB_TOKEN=your_github_token_here

# 目标仓库 (owner/repo 格式)
GITHUB_REPO=yourname/your-repo

# ============ LLM 配置 ============
# 可选：配置自定义 LLM（如 Minimax）
# 如果不配置，将使用本地 iFlow 默认配置（~/.iflow/settings.json）

# LLM 提供商: iflow, openai, minimax, custom
# LLM_PROVIDER=minimax

# API Key
# LLM_API_KEY=your_api_key

# API Base URL
# LLM_BASE_URL=https://api.minimaxi.com/v1

# 模型名称
# LLM_MODEL_NAME=MiniMax-M2.7-highspeed

# ============ 端口配置 ============

# 后端 API 端口
BACKEND_PORT=9500

# 前端 Dashboard 端口
FRONTEND_PORT=9501

# ============ 兼容旧配置 ============
# 以下配置也可用于 LLM（向后兼容）
# OPENAI_API_KEY=your_api_key
# OPENAI_API_BASE_URL=https://api.minimaxi.com/v1
# LLM_MODEL=openai/MiniMax-M2.7-highspeed

# ============ Worker Agent 配置 ============

# Worker 超时 (秒)
WORKER_TIMEOUT=600

# 轮询间隔 (秒)
POLL_INTERVAL=60

# 监听的 Issue 标签
ISSUE_LABEL=swallow

# 基础分支
BASE_BRANCH=main
